{
     "version": 2,
    "builds": [
          {
                  "src": "api/index.ts",
                  "use": "@vercel/node"
          },
          {
                  "src": "frontend/package.json",
                  "use": "@vercel/static-build",
                  "config": { "distDir": "dist" }
          }
    ],
    "rewrites": [
          {
                  "source": "/expenses(.*)",
                  "destination": "/api/index.ts"
          },
          {
                  "source": "/summary",
                  "destination": "/api/index.ts"
          },
          {
                  "source": "/(.*)",
                  "destination": "/frontend/dist/$1"
          }
    ]
}
